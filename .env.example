# AI Travel Agent - Environment Configuration Template
# Copy this file to .env and fill in your API keys

# =================
# REQUIRED API KEYS
# =================

# SerpAPI - For flight and hotel search functionality
# Get your API key from: https://serpapi.com
SERPAPI_API_KEY=your_serpapi_key_here

# SendGrid - For email delivery functionality  
# Get your API key from: https://sendgrid.com
SENDGRID_KEY=your_sendgrid_api_key_here

# =================
# OPTIONAL CONFIG
# =================

# Ollama Configuration (if running on different host/port)
# Default: http://localhost:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1

# Email Configuration
# Default sender email (update in email_agent.py if needed)
DEFAULT_SENDER_EMAIL=your-email@domain.com

# =================
# NOTES
# =================
# 1. Never commit this file to version control
# 2. Ensure Ollama is running locally: `ollama serve`
# 3. Install required model: `ollama pull llama3.2`
# 4. Test API keys before running the application